{
  "name": "@hansogj/music-utils",
  "version": "1.5.1",
  "description": "music tools for my flac & mp3 collection",
  "main": "",
  "bin": {
    "music-utils-rip": "build/run/rip.js",
    "music-utils-album-tag": "build/run/tag.album.js",
    "music-utils-tracks-tag": "build/run/tag.tracks.js",
    "music-utils-cover-photo": "build/run/cover.photo.js",
    "music-utils-album-cover": "build/run/tag.cover.album.js",
    "music-utils-bulk-album-tag": "build/run/bulk.tag.album.js",
    "music-utils-bulk-cover-photo": "build/run/bulk.cover.photo.js",
    "music-utils-sync-tracks": "build/run/sync.track.names.js",
    "music-utils-similarities": "build/run/similarities.js",
    "music-utils-completion": "build/run/completion.js"
  },
  "minimumReleaseAge": 10800,
  "scripts": {
    "build": "run-s clear tsc -- --declaration",
    "clear": "rm -rf ./build  ./build.ci  ./test-data/copy ",
    "format:check": "prettier --check src/ test-data/ ci/ --ignore-path=../../.prettierignore",
    "format:fix": "pnpm run format:check --  --write",
    "format:lint:fix": "pnpm run lint -- --fix && pnpm run format:fix",
    "lint": "eslint .",
    "sync_test_data": "rsync -a ./test-data/raw/* ./test-data/copy",
    "tsc": "tsc  --project ./tsconfig.build.json",
    "pretest": "run-s clear sync_test_data tsc",
    "ci:tsc": "tsc --project ./tsconfig.ci.json",
    "ci:pre": "run-s  clear pretest ci:tsc",
    "ci:tag:tracks": "run-s  ci:pre &&  ./ci/tag-tracks/run.sh",
    "ci:tag:zep1": "run-s  ci:pre &&  ./ci/tag-album/run.zep1.sh",
    "ci:tag:zep2": "run-s  ci:pre &&  ./ci/tag-album/run.zep2.sh",
    "ci:tag:acc": "run-s  ci:pre &&  ./ci/tag-album/run.acc.sh",
    "ci:prompt": "run-s  ci:pre && node ./build.ci/ci/prompt/run.js",
    "ci:run-all": "NO_PROMPT=TRUE run-s ci:tag:tracks ci:tag:zep1 ci:tag:zep2 ci:tag:acc ci:prompt",
    "vitest": "vitest run",
    "vitest:ci": "vitest run --coverage --reporter=default --reporter=junit --outputFile.junit=junit-TEST.xml",
    "vitest:watch": "vitest watch",
    "test": "run-s vitest vitest:ci ci:run-all",
    "precommit": "run-s test lint format:check tsc build"
  },
  "files": [
    "build"
  ],
  "keywords": [
    "music",
    "flac",
    "mp3"
  ],
  "author": "hansogj@gmail.com",
  "license": "UNLICENSED",
  "dependencies": {
    "@hansogj/array.utils": "3.0.0",
    "@hansogj/discogs-cover": "workspace:*",
    "@hansogj/discogs-item-lookup": "workspace:*",
    "@hansogj/maybe": "2.7.1",
    "chalk": "4.1.2",
    "dotenv": "17.4.2",
    "prompts": "2.4.2",
    "reflect-metadata": "0.2.2"
  },
  "devDependencies": {
    "@eslint/compat": "2.1.0",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@types/node": "26.1.0",
    "@types/prompts": "2.4.9",
    "@typescript-eslint/eslint-plugin": "8.62.1",
    "@typescript-eslint/parser": "8.62.1",
    "@vitest/coverage-v8": "3.2.7",
    "eslint": "10.6.0",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "globals": "17.7.0",
    "graceful-fs": "4.2.11",
    "nodemon": "3.1.14",
    "npm-run-all2": "9.0.2",
    "prettier": "3.9.4",
    "ts-node-dev": "2.0.0",
    "typescript-eslint": "8.62.1",
    "vitest": "3.2.7"
  }
}
